# ===========================================
# UNISTYLES E-COMMERCE - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ===========================================
# DATABASE
# ===========================================
DB_PASSWORD=your_secure_database_password_here

# ===========================================
# REDIS
# ===========================================
REDIS_PASSWORD=your_secure_redis_password_here

# ===========================================
# JWT AUTHENTICATION
# ===========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_64_characters_long

# ===========================================
# WHATSAPP BUSINESS
# ===========================================
WHATSAPP_NUMBER=+59990000425

# ===========================================
# SENTOO PAYMENT (Curacao)
# ===========================================
SENTOO_API_KEY=your_sentoo_api_key
SENTOO_MERCHANT_ID=your_sentoo_merchant_id
SENTOO_WEBHOOK_SECRET=your_sentoo_webhook_secret

# ===========================================
# EMAIL (for order confirmations)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=Unistyles <info@unistylescuracao.com>

# ===========================================
# SITE CONFIG
# ===========================================
SITE_URL=https://unistylescuracao.com
SITE_NAME=Unistyles Curacao

# ===========================================
# SSL (Production)
# ===========================================
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem
