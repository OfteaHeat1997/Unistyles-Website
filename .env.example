# ===========================================
# UNISTYLES E-COMMERCE - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# For Coolify deployment use .env.coolify.example as the checklist.

# ===========================================
# DATABASE
# ===========================================
DB_PASSWORD=your_secure_database_password_here

# ===========================================
# REDIS
# ===========================================
REDIS_PASSWORD=your_secure_redis_password_here

# ===========================================
# JWT AUTHENTICATION (backend)
# ===========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_64_characters_long

# ===========================================
# PUBLIC URLs (used by backend CORS, Directus CORS, and as build args)
# ===========================================
FRONTEND_URL=https://unistylescuracao.com
BACKEND_URL=https://api.unistylescuracao.com
DIRECTUS_URL=https://cms.unistylescuracao.com
SITE_URL=https://unistylescuracao.com
SITE_NAME=Unistyles Curacao

# ===========================================
# WHATSAPP BUSINESS
# ===========================================
WHATSAPP_NUMBER=+59996736285

# ===========================================
# WHATSAPP CLOUD API (Optional - enables automated messaging)
# Get credentials from Meta Developer Dashboard: https://developers.facebook.com/
# ===========================================
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=your_random_webhook_verify_string
WHATSAPP_APP_SECRET=

# ===========================================
# SENTOO PAYMENT (Curacao)
# Get credentials from Sentoo Portal: https://portal.sentoo.io
# ===========================================
SENTOO_API_KEY=your_sentoo_secret_key
SENTOO_MERCHANT_ID=your_sentoo_merchant_uid
SENTOO_SANDBOX=true

# ===========================================
# EMAIL (for order confirmations)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=Unistyles <info@unistylescuracao.com>

# ===========================================
# DIRECTUS CMS
# ===========================================
# KEY and SECRET: generate each with
#   node -e "console.log(require('crypto').randomUUID())"
DIRECTUS_KEY=replace_with_uuid_v4
DIRECTUS_SECRET=replace_with_uuid_v4
DIRECTUS_ADMIN_EMAIL=admin@unistylescuracao.com
DIRECTUS_ADMIN_PASSWORD=ChangeMe_StrongPassword!

# ===========================================
# FRONTEND (Vite build args — baked in at image build time)
# ===========================================
# Public URLs the browser will hit. Match BACKEND_URL / DIRECTUS_URL above
# unless you're using a different proxy hostname for clients.
FRONTEND_VITE_API_URL=https://api.unistylescuracao.com
FRONTEND_VITE_DIRECTUS_URL=https://cms.unistylescuracao.com
FRONTEND_VITE_USE_CMS=true
