# ===========================================
# COOLIFY DEPLOYMENT — Environment Checklist
# ===========================================
# Paste these into Coolify → Resource → Environment Variables.
# Mark all secret-looking values as "Secret" (the eye/lock icon) so they
# don't appear in compose-rendered logs.
#
# Build-time vars (FRONTEND_VITE_*) must also be set under
# "Build-time Environment Variables" so Vite picks them up at image build.

# --- DATA SERVICES ---------------------------------------------------------
DB_PASSWORD=                         # secret
REDIS_PASSWORD=                      # secret

# --- BACKEND ---------------------------------------------------------------
JWT_SECRET=                          # secret, 64+ hex chars

# Public URLs — these drive CORS allowlist, Directus PUBLIC_URL,
# and Sentoo / WhatsApp callback URLs. Change if your domains differ.
FRONTEND_URL=https://unistylescuracao.com
BACKEND_URL=https://api.unistylescuracao.com
DIRECTUS_URL=https://cms.unistylescuracao.com
SITE_URL=https://unistylescuracao.com

# --- WHATSAPP --------------------------------------------------------------
WHATSAPP_NUMBER=+59996736285
WHATSAPP_ACCESS_TOKEN=               # secret (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=               # secret, random string
WHATSAPP_APP_SECRET=                 # secret

# --- SENTOO ----------------------------------------------------------------
SENTOO_API_KEY=                      # secret
SENTOO_MERCHANT_ID=
SENTOO_SANDBOX=false                 # flip to true for test gateway

# --- EMAIL -----------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=                       # secret
EMAIL_FROM=Unistyles <info@unistylescuracao.com>

# --- DIRECTUS --------------------------------------------------------------
DIRECTUS_KEY=                        # secret, UUID v4
DIRECTUS_SECRET=                     # secret, UUID v4
DIRECTUS_ADMIN_EMAIL=admin@unistylescuracao.com
DIRECTUS_ADMIN_PASSWORD=             # secret, only used on first boot to create admin

# --- FRONTEND BUILD ARGS (set under Build-time Env in Coolify) -------------
FRONTEND_VITE_API_URL=https://api.unistylescuracao.com
FRONTEND_VITE_DIRECTUS_URL=https://cms.unistylescuracao.com
FRONTEND_VITE_USE_CMS=true
