# ===========================================
# UNISTYLES BACKEND - Development Dockerfile
# Hot reload with nodemon
# ===========================================

FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev)
RUN npm install

# Copy source files
COPY . .

# Expose API port
EXPOSE 3000

# Start with nodemon for hot reload
CMD ["npm", "run", "dev"]
