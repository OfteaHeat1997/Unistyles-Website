{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Product catalog for Unistyles Curacao"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "ref": {
      "type": "string",
      "required": false
    },
    "description": {
      "type": "text"
    },
    "price": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "compareAtPrice": {
      "type": "decimal",
      "min": 0
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    },
    "color": {
      "type": "string"
    },
    "size": {
      "type": "string"
    },
    "style": {
      "type": "string"
    },
    "compression": {
      "type": "enumeration",
      "enum": ["light", "medium", "firm"]
    },
    "material": {
      "type": "string"
    },
    "badge": {
      "type": "enumeration",
      "enum": ["new", "bestseller", "premium", "sale", "gift_set", "pack_3"]
    },
    "inStock": {
      "type": "boolean",
      "default": true
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "products"
    },
    "brand": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::brand.brand",
      "inversedBy": "products"
    },
    "legacyId": {
      "type": "string",
      "private": true
    },
    "legacyImage": {
      "type": "string"
    },
    "gender": {
      "type": "enumeration",
      "enum": ["women", "men", "unisex"],
      "default": "unisex"
    },
    "fragranceFamily": {
      "type": "enumeration",
      "enum": ["floral", "oriental", "woody", "fresh", "fruity", "gourmand", "citrus", "aquatic"]
    },
    "scentProfile": {
      "type": "enumeration",
      "enum": ["sweet", "spicy", "musky", "powdery", "green", "aromatic", "warm", "cool"]
    },
    "intensity": {
      "type": "enumeration",
      "enum": ["light", "moderate", "intense", "very_intense"]
    },
    "occasion": {
      "type": "enumeration",
      "enum": ["daily", "office", "evening", "romantic", "special", "casual", "sport"]
    },
    "season": {
      "type": "enumeration",
      "enum": ["spring", "summer", "fall", "winter", "all_year"]
    },
    "topNotes": {
      "type": "string"
    },
    "middleNotes": {
      "type": "string"
    },
    "baseNotes": {
      "type": "string"
    },
    "volume": {
      "type": "string"
    },
    "concentration": {
      "type": "enumeration",
      "enum": ["parfum", "edp", "edt", "cologne", "splash"]
    }
  }
}
