{
  "kind": "singleType",
  "collectionName": "business_settings",
  "info": {
    "singularName": "business-setting",
    "pluralName": "business-settings",
    "displayName": "Business Settings",
    "description": "Store configuration, contact info, delivery settings"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "storeName": {
      "type": "string",
      "required": true,
      "default": "Unistyles Curacao"
    },
    "tagline": {
      "type": "string"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "email": {
      "type": "email"
    },
    "phone": {
      "type": "string"
    },
    "whatsappNumber": {
      "type": "string"
    },
    "address": {
      "type": "text"
    },
    "currency": {
      "type": "string",
      "default": "XCG"
    },
    "currencySymbol": {
      "type": "string",
      "default": "XCG"
    },
    "freeDeliveryThreshold": {
      "type": "decimal",
      "default": 150
    },
    "deliveryFee": {
      "type": "decimal",
      "default": 10
    },
    "deliveryZones": {
      "type": "json"
    },
    "paymentMethods": {
      "type": "json"
    },
    "socialLinks": {
      "type": "json"
    },
    "businessHours": {
      "type": "json"
    },
    "maintenanceMode": {
      "type": "boolean",
      "default": false
    },
    "maintenanceMessage": {
      "type": "text"
    }
  }
}
