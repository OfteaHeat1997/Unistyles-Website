{
  "kind": "singleType",
  "collectionName": "homepages",
  "info": {
    "singularName": "homepage",
    "pluralName": "homepages",
    "displayName": "Homepage",
    "description": "Homepage content and hero slides"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "heroSlides": {
      "type": "component",
      "repeatable": true,
      "component": "homepage.hero-slide"
    },
    "featuredCategories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::category.category"
    },
    "featuredProducts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product"
    },
    "newArrivals": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product"
    },
    "promoBanner": {
      "type": "component",
      "repeatable": false,
      "component": "homepage.promo-banner"
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "text"
    }
  }
}
