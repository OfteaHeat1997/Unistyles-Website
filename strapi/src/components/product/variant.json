{
  "collectionName": "components_product_variants",
  "info": {
    "displayName": "Variant",
    "description": "Color and size variant of a product (used for bras, panties, shapewear)",
    "icon": "tags"
  },
  "options": {},
  "attributes": {
    "sku": {
      "type": "string",
      "required": true
    },
    "color": {
      "type": "string"
    },
    "size": {
      "type": "string"
    },
    "price": {
      "type": "decimal",
      "min": 0
    },
    "stockQuantity": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "inStock": {
      "type": "boolean",
      "default": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    }
  }
}
